# 环境变量示例
# 复制此文件为 .env，填入真实值
# .env 永远不要提交到 git

# 未来要接的文献 API key（暂时不用，先占位）
CROSSREF_API=
OPENALEX_API=
SERP_API=

# Crossref API 用（无 key，但 Crossref 鼓励设 polite email）
# server.py 调 https://api.crossref.org/works/{doi} 时，会把这个邮箱塞到
# User-Agent 的 mailto 字段里，方便 Crossref 遇到滥用时联系。
# 默认值 yc1376772@gmail.com 已写在 server.py 里，无需在 .env 里改
CROSSREF_POLITE_EMAIL=your-email@example.com

# Unpaywall 邮箱（PDF 下载成功率 +30%）
# fetch.py 用这个调 https://api.unpaywall.org/v2/<doi>?email=xxx
# 填你的真实邮箱即可，不需要注册
UNPAYWALL_EMAIL=your-email@example.com
